# ── Agent 01 — Resident Services & 311 ───────────────────────────────────────
EXTRACT_MODE=demo                 # demo (no LLM) | live
CONNECTOR_MODE=fixture            # fixture | live
LLM_PROVIDER=anthropic            # anthropic | bedrock
# ANTHROPIC_API_KEY=...            # required only for LLM_PROVIDER=anthropic
# --- Bedrock (in-account, no PII egress) ---
# BEDROCK_REGION=us-east-1         # us-gov-west-1 in GovCloud
# BEDROCK_GUARDRAIL_ID=...         # REQUIRED in production
# BEDROCK_GUARDRAIL_VERSION=DRAFT
# ENVIRONMENT=production           # makes the guardrail mandatory
# --- Live connectors (point at the agency systems) ---
# CRM311_BASE_URL=https://311.city.example.gov
# KB_BASE_URL=https://kb.city.example.gov
# SCHEDULING_BASE_URL=https://appts.city.example.gov
# --- Gateway audit sink ---
# GATEWAY_AUDIT_JSONL=/var/log/slg/gateway-audit.jsonl
